<!DOCTYPE html>
<html lang="<%= config.language || 'ko' %>">
  <head>
    <%- partial('partials/head') %>
  </head>
  <body class="<%= is_post() ? 'is-post-page' : 'is-home-page' %>">
    <div id="container">
      <div id="wrap">
        <%- partial('partials/header') %>
        <div class="outer">
          <section id="main">
            <%- body %>
          </section>
          <%- partial('partials/sidebar') %>
        </div>
        <%- partial('partials/footer') %>
      </div>
      <%- partial('partials/mobile-nav') %>
    </div>
    <script src="<%= url_for('/js/reasonofmoon.js') %>"></script>
  </body>
</html>
